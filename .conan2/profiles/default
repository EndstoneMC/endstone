[settings]
os={{ detect_api.detect_os() }}
arch={{ detect_api.detect_arch() }}
build_type=Release
&:build_type=RelWithDebInfo
{% if platform.system() == "Windows" %}
{% set compiler, version, _ = detect_api.detect_msvc_compiler() %}
compiler={{ compiler }}
compiler.version={{ detect_api.default_compiler_version(compiler, version) }}
compiler.runtime=dynamic
{% else %}
{% set compiler, version, _ = detect_api.detect_clang_compiler() %}
compiler={{ compiler }}
compiler.version={{ detect_api.default_compiler_version(compiler, version) }}
compiler.libcxx=libc++
{% endif %}
compiler.cppstd=20

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
{% if platform.system() == "Windows" %}
tools.build:compiler_executables={"c": "clang-cl", "cpp": "clang-cl"}
sentry-native/*:tools.build:compiler_executables={"c": "cl", "cpp": "cl"}
{% else %}
tools.system.package_manager:mode=install
tools.build:compiler_executables={"c": "/usr/bin/clang", "cpp": "/usr/bin/clang++"}
{% endif %}

[replace_requires]
fmt/11.2.0: fmt/12.1.0