# Copy this file to .env and adjust the values for your host:
#   cp .env.example .env

# User and group IDs the server runs as. Set these to your host user's
# `id -u` / `id -g` so files written to ./data stay owned by you.
PUID=1000
PGID=1000

# Container time zone, used for log timestamps (e.g. Europe/London).
TZ=UTC
