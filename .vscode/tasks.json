{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Conan: Install",
            "type": "process",
            "command": "conan",
            "args": [
                "install",
                ".",
                "-of",
                "build/conan_out",
                "--build=missing"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Project: Configure",
            "type": "cmake",
            "command": "configure",
            "preset": "conan-relwithdebinfo",
            "dependsOn": [
                "Conan: Install"
            ],
            "problemMatcher": []
        },
        {
            "label": "Project: Build",
            "type": "cmake",
            "command": "build",
            "preset": "conan-relwithdebinfo",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Project: Install",
            "type": "shell",
            "command": "rm -rf build/package && uv pip install -U . -C build-dir=./build --verbose",
            "windows": {
                "command": "Remove-Item -Recurse -Force build/package; uv pip install -U . -C build-dir=./build --verbose"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Scripts: Dump Symbols",
            "type": "shell",
            "command": "uv run --script dump_symbols.py",
            "options": {
                "cwd": "${workspaceFolder}/scripts"
            },
            "problemMatcher": []
        }
    ]
}