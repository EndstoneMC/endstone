{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install",
            "type": "shell",
            "command": "rm -rf ./build/package && uv pip install -U . -C build-dir=./build -v",
            "windows": {
                "command": "Remove-Item -Recurse -Force .\\build\\package -ErrorAction SilentlyContinue; uv pip install -U . -C build-dir=./build -v"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "uv run --no-project endstone",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Install",
            "dependsOrder": "sequence",
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "^never-matches-anything$"
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.+$",
                    "endsPattern": "^.+$"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "clear": false
            }
        }
    ]
}