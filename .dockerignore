# Keep .git — setuptools_scm derives the wheel version from it.
# Keep tests/ — the image build runs `pytest tests`.

# Build outputs
build
dist
stubs
wheelhouse
CMakeUserPresets.json
*.egg-info

# Virtual environments and caches
.cache
.venv
venv
__pycache__
*.pyc
.pytest_cache

# Server data
bedrock_server
data

# Editor and local config (untracked paths only — excluding a git-tracked path
# here makes the build tree look dirty to setuptools_scm).
.idea
.vscode
.claude
.env
